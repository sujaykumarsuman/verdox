{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TestDashboard",
  "description": "Schema for test dashboard API request body",
  "type": "object",
  "required": ["repo", "run_id", "timestamp", "jobs"],
  "properties": {
    "repo": {
      "type": "string",
      "description": "Repository identifier (e.g. hashicorp/consul)"
    },
    "run_id": {
      "type": "string",
      "description": "CI run ID or commit SHA that triggered this report"
    },
    "branch": {
      "type": "string",
      "description": "Git branch name"
    },
    "commit_sha": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "description": "Roll-up stats across all suites (rendered at dashboard top)",
      "properties": {
        "total_jobs": { "type": "integer" },
        "total_tests": { "type": "integer" },
        "total_cases": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" },
        "duration_seconds": { "type": "number" },
        "pass_rate": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "required": ["total_jobs", "total_tests", "total_cases", "passed", "failed", "skipped"]
    },
    "jobs": {
      "type": "array",
      "description": "Level 1: CI jobs (unit, integration, e2e, race, lint, build, etc.)",
      "items": {
        "$ref": "#/definitions/Job"
      }
    }
  },
  "definitions": {
    "Job": {
      "type": "object",
      "required": ["job_id", "name", "type", "status", "tests"],
      "properties": {
        "job_id": {
          "type": "string",
          "description": "Unique slug (e.g. backend-test, frontend-lint)"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name"
        },
        "type": {
          "type": "string",
          "enum": ["unit", "integration", "e2e", "race", "lint", "build", "compatibility", "load"],
          "description": "Category of test suite"
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "skipped", "running", "unknown"]
        },
        "stats": {
          "$ref": "#/definitions/Stats"
        },
        "tests": {
          "type": "array",
          "description": "Level 2: Test groups (packages/features being tested)",
          "items": {
            "$ref": "#/definitions/Test"
          }
        }
      }
    },
    "Test": {
      "type": "object",
      "required": ["test_id", "name", "package", "status", "cases"],
      "properties": {
        "test_id": {
          "type": "string",
          "description": "Unique slug (e.g. agent-consul-acl)"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name (e.g. ACL System)"
        },
        "package": {
          "type": "string",
          "description": "Go package path (e.g. github.com/hashicorp/consul/agent/consul)"
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "skipped", "running", "unknown"]
        },
        "stats": {
          "$ref": "#/definitions/Stats"
        },
        "cases": {
          "type": "array",
          "description": "Level 3: Individual test cases",
          "items": {
            "$ref": "#/definitions/TestCase"
          }
        }
      }
    },
    "TestCase": {
      "type": "object",
      "required": ["case_id", "name", "status"],
      "properties": {
        "case_id": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "Test function name (e.g. TestACLResolver_Disabled)"
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "skipped", "running", "unknown"]
        },
        "duration_seconds": {
          "type": "number"
        },
        "error_message": {
          "type": "string",
          "description": "Populated only on failure"
        },
        "stack_trace": {
          "type": "string",
          "description": "Populated only on failure"
        },
        "retry_count": {
          "type": "integer",
          "default": 0
        },
        "logs_url": {
          "type": "string",
          "format": "uri",
          "description": "Link to CI logs for this case"
        }
      }
    },
    "Stats": {
      "type": "object",
      "properties": {
        "total": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" },
        "duration_seconds": { "type": "number" },
        "pass_rate": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    }
  }
}
